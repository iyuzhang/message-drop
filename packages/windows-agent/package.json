{
  "name": "windows-agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "main.cjs",
  "description": "Windows tray agent for message-drop",
  "scripts": {
    "start": "electron ./main.cjs",
    "build:server-runtime": "esbuild ../../src/server.ts --bundle --platform=node --format=cjs --outfile=dist-resources/server/server.cjs",
    "build:web-runtime": "pnpm --dir ../../web run build && node ./scripts/prepare-web-runtime.mjs",
    "dist:win": "pnpm run build:server-runtime && pnpm run build:web-runtime && electron-builder --win",
    "test": "node --test"
  },
  "build": {
    "productName": "Message Drop",
    "appId": "com.messagedrop.windows.agent",
    "files": [
      "main.cjs",
      "lib/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-resources/server/server.cjs",
        "to": "server/server.cjs"
      },
      {
        "from": "dist-resources/web/dist",
        "to": "web/dist"
      }
    ],
    "win": {
      "icon": "assets/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.27.4"
  }
}
