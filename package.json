{
  "name": "message-drop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "verify:phase1": "tsx scripts/verify-phase1.ts",
    "verify:phase2": "tsx scripts/verify-phase2.ts",
    "verify:phase3": "tsx scripts/verify-phase3.ts && pnpm --dir web run build",
    "verify:phase4": "tsx scripts/verify-phase4.ts && pnpm --dir web run build",
    "verify:phase5": "tsx scripts/verify-phase5.ts",
    "verify:all": "pnpm run verify:phase1 && pnpm run verify:phase2 && pnpm run verify:phase3 && pnpm run verify:phase4 && pnpm run verify:phase5 && pnpm run verify:phase6",
    "dev:server": "tsx watch src/server.ts",
    "dev:web": "pnpm --dir web dev",
    "typecheck": "tsc --noEmit",
    "verify:phase6": "bash scripts/verify-phase6.sh"
  },
